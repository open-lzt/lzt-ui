{
  "name": "@open-lzt/ui",
  "version": "0.1.0",
  "description": "LZT design system — CSS kit, icon set and React bindings shared across the open-lzt ecosystem",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-lzt/lzt-ui.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./lzt-ui.css": "./lzt-ui.css",
    "./lzt-ui.js": "./lzt-ui.js",
    "./lzt-icons.js": "./lzt-icons.js"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "lzt-ui.css",
    "lzt-ui.js",
    "lzt-icons.js"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.3.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  }
}
